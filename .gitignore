# Images (debug shots, snapshots, captures) — never committed
*.jpg
*.jpeg
*.png
*.bmp

# EXCEPTION: the showcase document + its images live in docs/ and ARE
# tracked (the Pi skips docs/ via sparse-checkout, so they don't bloat the
# rig — see deploy/CHEATSHEET.md). The big standalone wiring PNGs stay out.
!docs/
!docs/*.docx
!docs/*.js
!docs/*.png
!docs/*.jpg
!docs/*.jpeg

# Node deps for the docs generator (npm install docx) — never committed
node_modules/
package-lock.json

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
venv/
env/

# Claude Code local state
.claude/

# Session / game data (local records, not source)
session.csv
session.json
session_report.txt
test_report.txt
dice_tracker.db
eval_sessions/
retrain_candidates/
align_snapshots/

# Captured frames and training artifacts (large; models go to Pi via SCP)
capture_sessions/
training_data/
live_samples/
training/datasets/
training/runs/
training/models/
training/recordings/
training/live_snapshots/
training/sanity_check/

# Model binaries (pretrained checkpoints auto-download; ONNX via SCP)
*.pt
*.pth
*.onnx

# Misc
*.log
training/train_log*.txt
training/train_err*.txt
.DS_Store
Thumbs.db

# Wiring reference diagrams are NOT committed: they're reference material
# for building the rig, the Pi never reads them, and at ~12 MB each they
# bloated every pull on the Pi (caused fetch resets on slow links
# 2026-06-17). They live on the build PC; regenerate from DESIGN.md's pin
# map if needed. (They fall under the *.png ignore above — no override.)
